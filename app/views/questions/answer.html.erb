<div class="horror-wrap">
  <div class="horror-card">
    <h1 class="horror-title">The coach heard you…</h1>
    <p class="horror-subtitle">And he’s not impressed.</p>

    <div class="horror-block">
      <p class="horror-kicker">You asked:</p>
      <p class="horror-text"><%= @question %></p>
    </div>

    <div class="horror-block">
      <p class="horror-kicker">Coach answers:</p>
      <p class="horror-text horror-answer"><%= @answer %></p>
    </div>

    <%= link_to "Ask another question", ask_path, class: "horror-link" %>
  </div>
</div>
