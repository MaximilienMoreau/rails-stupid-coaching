<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow-sm mb-3">
        <div class="card-body p-4">
          <p class="text-muted mb-1">You asked:</p>
          <p class="fs-5 mb-4"><%= @question %></p>

          <p class="text-muted mb-1">Coach answers:</p>
          <p class="fs-5 fw-semibold"><%= @answer %></p>
        </div>
      </div>

      <div class="text-center">
        <%= link_to "Ask another question", ask_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>
