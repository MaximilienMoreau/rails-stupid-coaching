<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h1 class="h4 mb-3">Ask your coach anything</h1>

          <form action="/answer" data-turbo="false">
            <div class="mb-3">
              <label for="question" class="form-label">Your question</label>
              <input type="text" id="question" name="question" class="form-control" placeholder="e.g. What time is it?">
            </div>

            <input type="submit" value="Ask!" class="btn btn-primary w-100">
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
