<div class="horror-wrap">
  <div class="horror-card">
    <h1 class="horror-title">Stupid Coaching <span class="blood">after midnight</span></h1>
    <p class="horror-subtitle">Ask your coach anything… if you dare.</p>

    <form action="/answer" data-turbo="false">
      <label for="question" class="horror-label">Your question</label>
      <input
        type="text"
        id="question"
        name="question"
        class="horror-input"
        placeholder="e.g. What time is it?"
        autocomplete="off"
      >
      <input type="submit" value="Ask!" class="horror-btn">
    </form>
  </div>
</div>
